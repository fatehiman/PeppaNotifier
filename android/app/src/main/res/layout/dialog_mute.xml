<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:text="@string/mute_title"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp">
        <Button
            android:id="@+id/btn_5m"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_5m" />
        <Button
            android:id="@+id/btn_15m"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_15m" />
        <Button
            android:id="@+id/btn_1h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_1h" />
        <Button
            android:id="@+id/btn_2h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_2h" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">
        <Button
            android:id="@+id/btn_3h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_3h" />
        <Button
            android:id="@+id/btn_8h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_8h" />
        <Button
            android:id="@+id/btn_10h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_10h" />
        <Button
            android:id="@+id/btn_12h"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_12h" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp">
        <Button
            android:id="@+id/btn_2d"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/mute_2days" />
        <Button
            android:id="@+id/btn_unmute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:minWidth="0dp"
            android:text="@string/action_unmute"
            android:textColor="#991B1B" />
    </LinearLayout>
</LinearLayout>
